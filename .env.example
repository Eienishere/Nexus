# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Note: DB_ENCRYPTION_KEY has been removed.
# Nexus now uses a Zero-Knowledge Master Password system.
# The user creates a master password in the web UI at first startup,
# which is used with Argon2id to derive the DB encryption key.
# The key only exists in RAM and is completely removed from the environment.
